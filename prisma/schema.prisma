generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  date      DateTime
  isHoliday Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
